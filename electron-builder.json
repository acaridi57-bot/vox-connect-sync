{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "it.speaklivetranslate",
  "productName": "SpeakLive Translate",
  "extraMetadata": { "main": "index.js", "type": "commonjs" },
  "beforePack": "./electron-builder-beforePack.cjs",
  "afterPack": "./electron-builder-afterPack.cjs",
  "asar": true,
  "npmRebuild": false,
  "nodeGypRebuild": false,
  "buildDependenciesFromSource": false,
  "removePackageScripts": true,
  "directories": { "output": "release", "buildResources": "build-resources" },
  "files": ["dist/**/*", "electron/**/*", "index.js", "package.json"],
  "mac": {
    "category": "public.app-category.utilities",
    "icon": "public/icon.icns",
    "target": [
      { "target": "dmg", "arch": ["x64", "arm64"] },
      { "target": "zip", "arch": ["x64", "arm64"] }
    ],
    "darkModeSupport": true,
    "hardenedRuntime": false,
    "gatekeeperAssess": false,
    "identity": null
  },
  "dmg": {
    "contents": [{ "x": 130, "y": 220 }, { "x": 410, "y": 220, "type": "link", "path": "/Applications" }],
    "window": { "width": 540, "height": 380 }
  },
  "win": {
    "icon": "public/icon.png",
    "target": [{ "target": "nsis", "arch": ["x64", "ia32"] }]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "SpeakLive Translate"
  }
}
